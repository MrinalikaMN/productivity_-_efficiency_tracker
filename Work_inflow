<!DOCTYPE html>
<html>
<head>
<title>Workflow Productivity Tracker</title>

<style>
body{
font-family: Arial;
background:#f4f6f8;
padding:40px;
}

.container{
width:600px;
margin:auto;
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

h1{
text-align:center;
}

input, select{
width:100%;
padding:10px;
margin:8px 0;
}

button{
background:#007bff;
color:white;
border:none;
padding:10px;
width:100%;
cursor:pointer;
}

table{
margin-top:20px;
width:100%;
border-collapse:collapse;
}

th,td{
border:1px solid #ddd;
padding:8px;
text-align:center;
}

th{
background:#007bff;
color:white;
}
</style>
</head>

<body>

<div class="container">

<h1>Workflow Tracker</h1>

<label>Task Name</label>
<input type="text" id="taskName">

<label>Category</label>
<select id="category">
<option>Software</option>
<option>Education</option>
</select>

<label>Estimated Time (minutes)</label>
<input type="number" id="time">

<label>Priority</label>
<select id="priority">
<option>High</option>
<option>Medium</option>
<option>Low</option>
</select>

<button onclick="addTask()">Add Task</button>

<table id="taskTable">
<tr>
<th>Task</th>
<th>Category</th>
<th>Time</th>
<th>Priority</th>
</tr>
</table>

</div>

<script>

function addTask(){

let name=document.getElementById("taskName").value
let category=document.getElementById("category").value
let time=document.getElementById("time").value
let priority=document.getElementById("priority").value

let table=document.getElementById("taskTable")

let row=table.insertRow()

row.insertCell(0).innerHTML=name
row.insertCell(1).innerHTML=category
row.insertCell(2).innerHTML=time+" min"
row.insertCell(3).innerHTML=priority

document.getElementById("taskName").value=""
document.getElementById("time").value=""

}

</script>

</body>
</html>
